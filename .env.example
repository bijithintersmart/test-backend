# Server Configuration
PORT=3000
NODE_ENV=development

# Database Settings (PostgreSQL)
DATABASE_URL="postgresql://intersamrt:root@localhost:5432/enterprise_db?schema=public"

# Redis Settings
REDIS_URL="redis://localhost:6379"

# Authentication (JWT)
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# OAuth - Google
GOOGLE_CLIENT_ID="google-client-id-here"
GOOGLE_CLIENT_SECRET="google-client-secret-here"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# OAuth - Apple
APPLE_CLIENT_ID="apple-client-id-here"
APPLE_TEAM_ID="apple-team-id-here"
APPLE_KEY_ID="apple-key-id-here"
APPLE_PRIVATE_KEY="apple-private-key-here"
APPLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/apple/callback"

# Email Configuration (Nodemailer / SMTP)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="no-reply@enterprise.com"

# Storage Settings (Local / S3 / Cloudinary)
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID="aws-access-key"
AWS_SECRET_ACCESS_KEY="aws-secret-access-key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="enterprise-bucket"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX=100          # Limit each IP to 100 requests per windowMs
